# --- Frontend (Vite / Netlify) ---
# Local dev: leave VITE_API_BASE_URL unset so the app uses /api and Vite proxies to localhost:5000.
# Optional: point the SPA at your deployed API (include /api suffix)
# VITE_API_BASE_URL=https://your-service.onrender.com/api
# VITE_API_ORIGIN=https://your-service.onrender.com
#
# Media paths in the DB look like /assets/file.mp4. By default the browser loads them from the SAME
# origin as the site (put copies under public/assets/ in this repo). If media is served ONLY by the
# API (e.g. backend/public/assets on Render), set:
# VITE_ASSET_ORIGIN=https://your-service.onrender.com

# --- Backend (Render / local) ---
# JWT_SECRET=use-a-long-random-string-in-production
# PORTFOLIO_DB_PATH=/data/portfolio.db
#   Use a persistent disk path on Render so SQLite survives redeploys (mount disk, set this env).
